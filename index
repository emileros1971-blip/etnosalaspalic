
<!DOCTYPE html>
<html lang="sr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Etno Salaš Palić — Autentično Vojvođansko Domaćinstvo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Crimson+Pro:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --wheat: #e8c97a;
    --amber: #c4873a;
    --rust: #8b3e1a;
    --dark: #1a1208;
    --forest: #2d4a2a;
    --cream: #f5edd8;
    --parchment: #ede0c4;
    --smoke: #7a6e5f;
    --white: #fdfaf4;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Crimson Pro', Georgia, serif;
    background: var(--white);
    color: var(--dark);
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 999;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 20px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(26,18,8,0.85) 0%, transparent 100%);
    backdrop-filter: blur(2px);
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--wheat);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245, 237, 216, 0.8);
    text-decoration: none;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--wheat); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--dark);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(160deg, rgba(26,18,8,0.3) 0%, rgba(139,62,26,0.15) 40%, rgba(26,18,8,0.6) 100%),
      linear-gradient(to bottom, transparent 40%, rgba(26,18,8,0.95) 100%);
    z-index: 1;
  }

  /* Decorative field pattern */
  .hero-pattern {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-color: #2a1f0e;
    background-image:
      radial-gradient(ellipse 80% 50% at 60% 40%, rgba(196,135,58,0.18) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 20% 70%, rgba(45,74,42,0.3) 0%, transparent 60%),
      repeating-linear-gradient(
        85deg,
        transparent 0px,
        transparent 18px,
        rgba(232,201,122,0.04) 18px,
        rgba(232,201,122,0.04) 19px
      ),
      repeating-linear-gradient(
        175deg,
        transparent 0px,
        transparent 28px,
        rgba(232,201,122,0.03) 28px,
        rgba(232,201,122,0.03) 29px
      );
  }

  /* Photo grid in hero — shown when user uploads images */
  .hero-photos {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 3px;
  }

  .hero-photo-slot {
    overflow: hidden;
    position: relative;
  }

  .hero-photo-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 8s ease;
  }

  .hero-photo-slot img:hover { transform: scale(1.05); }

  /* placeholder slots */
  .hero-photo-slot:nth-child(1) { grid-column: 1 / 2; grid-row: 1 / 3; background: #1e1508 url('') center/cover; }
  .hero-photo-slot:nth-child(2) { background: #24180a; }
  .hero-photo-slot:nth-child(3) { background: #1a1208; }
  .hero-photo-slot:nth-child(4) { background: #2a1e0d; }
  .hero-photo-slot:nth-child(5) { background: #1e1508; }

  .hero-photo-placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 10px;
    color: rgba(232,201,122,0.2);
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .placeholder-icon { font-size: 2rem; opacity: 0.3; }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 80px 80px;
    max-width: 800px;
    animation: fadeUp 1.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--wheat);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hero-eyebrow::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--wheat);
    opacity: 0.6;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.05;
    margin-bottom: 24px;
  }

  .hero-title em {
    font-style: italic;
    color: var(--wheat);
  }

  .hero-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 300;
    color: rgba(245,237,216,0.7);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 48px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--amber);
    color: var(--dark);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 36px;
    transition: background 0.3s, gap 0.3s;
  }

  .hero-cta:hover { background: var(--wheat); gap: 20px; }

  .hero-scroll {
    position: absolute;
    bottom: 40px;
    right: 60px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(232,201,122,0.5);
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    animation: fadeUp 2s ease 0.5s both;
  }

  .hero-scroll::after {
    content: '';
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(232,201,122,0.4), transparent);
    animation: scrollPulse 2s ease infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  /* ── GALLERY UPLOAD SECTION ── */
  .gallery-section {
    background: var(--dark);
    padding: 100px 60px;
    text-align: center;
  }

  .section-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.8rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 16px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: var(--cream);
    margin-bottom: 16px;
  }

  .section-title em { font-style: italic; color: var(--wheat); }

  .section-body {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--smoke);
    max-width: 560px;
    margin: 0 auto 60px;
    line-height: 1.7;
  }

  /* Photo upload grid */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: auto auto auto;
    gap: 6px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Feature layout for first few photos */
  .photo-cell {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
    background: rgba(255,255,255,0.04);
    border: 1px dashed rgba(232,201,122,0.15);
    cursor: pointer;
    transition: border-color 0.3s;
  }

  .photo-cell:nth-child(1) { grid-column: 1 / 3; grid-row: 1 / 3; aspect-ratio: unset; min-height: 340px; }
  .photo-cell:nth-child(7) { grid-column: 4 / 6; grid-row: 2 / 4; aspect-ratio: unset; min-height: 260px; }

  .photo-cell:hover { border-color: rgba(232,201,122,0.4); }

  .photo-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }

  .photo-cell.has-image img { display: block; }
  .photo-cell.has-image .cell-placeholder { display: none; }

  .cell-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    color: rgba(232,201,122,0.2);
  }

  .cell-placeholder span { font-size: 1.5rem; }
  .cell-placeholder p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .upload-hint {
    margin-top: 40px;
    padding: 24px 40px;
    border: 1px solid rgba(232,201,122,0.2);
    display: inline-flex;
    align-items: center;
    gap: 16px;
    color: rgba(232,201,122,0.6);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
  }

  .upload-hint:hover {
    border-color: var(--amber);
    color: var(--wheat);
    background: rgba(196,135,58,0.08);
  }

  .upload-hint input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  /* ── AMENITIES ── */
  .amenities {
    background: var(--cream);
    padding: 120px 60px;
  }

  .amenities-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .amenities-text { }

  .amenities-text .section-label { color: var(--rust); }
  .amenities-text .section-title { color: var(--dark); margin-bottom: 24px; }
  .amenities-text .section-title em { color: var(--rust); }

  .amenities-desc {
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--smoke);
    margin-bottom: 40px;
  }

  .rating-badge {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    background: var(--dark);
    color: var(--cream);
    padding: 16px 28px;
  }

  .rating-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    color: var(--wheat);
    line-height: 1;
  }

  .rating-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    line-height: 1.4;
  }

  .rating-text strong { display: block; color: var(--wheat); font-size: 1rem; }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .feature-card {
    background: var(--parchment);
    padding: 32px 28px;
    border-left: 3px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }

  .feature-card:hover {
    border-left-color: var(--amber);
    background: white;
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 12px;
    display: block;
  }

  .feature-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: var(--dark);
    margin-bottom: 6px;
  }

  .feature-desc {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    color: var(--smoke);
    line-height: 1.6;
  }

  /* ── ROOMS ── */
  .rooms {
    background: var(--dark);
    padding: 120px 60px;
  }

  .rooms-header {
    max-width: 1200px;
    margin: 0 auto 70px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
  }

  .rooms-header .section-title { color: var(--cream); margin-bottom: 0; }
  .rooms-header .section-label { color: var(--amber); }

  .rooms-desc {
    max-width: 340px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--smoke);
    line-height: 1.7;
  }

  .rooms-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }

  .room-card {
    background: rgba(255,255,255,0.04);
    padding: 44px 36px;
    border: 1px solid rgba(232,201,122,0.08);
    transition: background 0.3s, border-color 0.3s;
    position: relative;
    overflow: hidden;
  }

  .room-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 0;
    background: var(--amber);
    transition: height 0.4s ease;
  }

  .room-card:hover::before { height: 100%; }
  .room-card:hover { background: rgba(232,201,122,0.04); border-color: rgba(232,201,122,0.2); }

  .room-num {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    color: rgba(232,201,122,0.12);
    line-height: 1;
    margin-bottom: 20px;
    font-style: italic;
  }

  .room-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--cream);
    margin-bottom: 16px;
  }

  .room-body {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    color: var(--smoke);
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .room-tags { display: flex; flex-wrap: wrap; gap: 8px; }

  .tag {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid rgba(196,135,58,0.3);
    padding: 5px 12px;
  }

  /* ── ACTIVITIES ── */
  .activities {
    background: var(--forest);
    padding: 120px 60px;
    position: relative;
    overflow: hidden;
  }

  .activities::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(45,74,42,0.0) 0%, rgba(232,201,122,0.06) 100%);
    border: 1px solid rgba(232,201,122,0.08);
  }

  .activities-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .activities-inner .section-label { color: var(--wheat); opacity: 0.7; }
  .activities-inner .section-title { color: var(--cream); margin-bottom: 60px; }

  .activities-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(232,201,122,0.1);
  }

  .activity-item {
    background: var(--forest);
    padding: 40px 30px;
    transition: background 0.3s;
  }

  .activity-item:hover { background: rgba(45,74,42,0.6); }

  .activity-emoji { font-size: 2.4rem; margin-bottom: 18px; display: block; }

  .activity-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    color: var(--cream);
    margin-bottom: 10px;
  }

  .activity-desc {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    color: rgba(245,237,216,0.55);
    line-height: 1.6;
  }

  /* ── NEARBY ── */
  .nearby {
    background: var(--parchment);
    padding: 100px 60px;
  }

  .nearby-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .nearby-inner .section-label { color: var(--rust); }
  .nearby-inner .section-title { color: var(--dark); margin-bottom: 12px; }
  .nearby-inner .section-body { color: var(--smoke); margin-bottom: 60px; }

  .nearby-items {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    border: 1px solid rgba(26,18,8,0.12);
  }

  .nearby-item {
    flex: 1;
    min-width: 180px;
    padding: 36px 24px;
    border-right: 1px solid rgba(26,18,8,0.1);
    text-align: center;
    transition: background 0.3s;
  }

  .nearby-item:last-child { border-right: none; }
  .nearby-item:hover { background: white; }

  .nearby-icon { font-size: 2rem; margin-bottom: 12px; display: block; }

  .nearby-name {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: var(--dark);
    margin-bottom: 6px;
  }

  .nearby-dist {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    color: var(--amber);
  }

  /* ── REVIEWS ── */
  .reviews {
    background: var(--cream);
    padding: 120px 60px;
  }

  .reviews-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .reviews-inner .section-label { color: var(--rust); }
  .reviews-inner .section-title { color: var(--dark); margin-bottom: 60px; }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }

  .review-card {
    background: var(--parchment);
    padding: 40px 36px;
    position: relative;
    transition: background 0.3s;
  }

  .review-card:hover { background: white; }

  .review-quote {
    font-family: 'Playfair Display', serif;
    font-size: 4rem;
    color: rgba(196,135,58,0.2);
    line-height: 0.5;
    margin-bottom: 20px;
    font-style: italic;
    display: block;
  }

  .review-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 300;
    color: var(--smoke);
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .review-stars {
    color: var(--amber);
    font-size: 0.9rem;
    margin-bottom: 10px;
    letter-spacing: 3px;
  }

  .review-author {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dark);
  }

  /* ── CONTACT ── */
  .contact {
    background: var(--dark);
    padding: 120px 60px;
    position: relative;
    overflow: hidden;
  }

  .contact::after {
    content: 'SALAŠ';
    position: absolute;
    bottom: -60px;
    right: -20px;
    font-family: 'Playfair Display', serif;
    font-size: 18vw;
    font-weight: 700;
    font-style: italic;
    color: rgba(232,201,122,0.03);
    line-height: 1;
    pointer-events: none;
  }

  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .contact-text .section-label { color: var(--amber); }
  .contact-text .section-title { color: var(--cream); margin-bottom: 24px; }
  .contact-text .section-title em { color: var(--wheat); }

  .contact-body {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: var(--smoke);
    line-height: 1.8;
    margin-bottom: 48px;
  }

  .contact-details { list-style: none; display: flex; flex-direction: column; gap: 20px; }

  .contact-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(232,201,122,0.08);
  }

  .contact-item:last-child { border-bottom: none; }

  .contact-icon {
    width: 44px;
    height: 44px;
    background: rgba(196,135,58,0.12);
    border: 1px solid rgba(196,135,58,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .contact-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--amber);
    display: block;
    margin-bottom: 4px;
  }

  .contact-value {
    font-family: 'Crimson Pro', serif;
    font-size: 1.05rem;
